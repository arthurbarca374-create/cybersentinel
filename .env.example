# Copy this file to .env and fill in your values
# Never commit .env to git

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

# PostgreSQL password (for Docker Compose)
DB_PASSWORD=change-me-use-openssl-rand-hex-32

# GitHub OAuth App (register free at https://github.com/settings/developers)
# Homepage URL:      http://localhost:8000
# Callback URL:      http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App URLs (update for production)
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
FRONTEND_URL=http://localhost:8000
ALLOWED_HOSTS=["yourdomain.com", "localhost"]

# Database — SQLite by default, switch to PostgreSQL in production
DATABASE_URL=sqlite:///./cybersentinel.db

# JWT config
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Trial limits
FREE_TRIAL_DAYS=14
FREE_TRIAL_SCANS=10

# Optional: set to true in dev
DEBUG=false

# ── AI / LLM Providers ──────────────────────────────────────
# Anthropic Claude (claude.ai)
ANTHROPIC_API_KEY=
# OpenAI (platform.openai.com)
OPENAI_API_KEY=
# Self-hosted LLM API (e.g. Ollama, LocalAI, vLLM)
LLM_API_URL=
LLM_MODEL=

# ── Threat Intel APIs ───────────────────────────────────────
# VirusTotal (virustotal.com)
VIRUSTOTAL_API_KEY=
# Shodan (shodan.io)
SHODAN_API_KEY=
# AbuseIPDB (abuseipdb.com)
ABUSEIPDB_API_KEY=

# ── Blockchain APIs ─────────────────────────────────────────
# Etherscan (etherscan.io) — free tier, optional for ETH analysis
ETHERSCAN_API_KEY=

# ── Notifications ───────────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scan Engine ─────────────────────────────────────────────
SCAN_TIMEOUT=300
STUCK_SCAN_THRESHOLD=600

# ── Worker ──────────────────────────────────────────────────
WORKER_POLL_INTERVAL=10
WORKER_CONCURRENCY=4
WORKER_CLEANUP_DAYS=90
